# Server Configuration
PORT=3501
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
# The backend requires a server-only elevated key for capture finalization.
# Prefer the modern secret key where the Supabase installation supports it.
SUPABASE_URL=http://your-supabase-url:8000
SUPABASE_SECRET_KEY=replace-with-your-supabase-secret-key
# Legacy compatibility only; use one of these if a secret key is unavailable.
SUPABASE_SERVICE_KEY=replace-with-your-service-role-key

# Capture API authentication for trusted callers such as n8n.
# JWT-authenticated browser requests do not need these settings.
MEDIA_API_KEY=replace-with-a-long-random-secret
MEDIA_API_KEY_USER_ID=replace-with-the-supabase-auth-user-uuid-for-n8n

# AI Service Configuration (MiniMax only)
MINIMAX_API_KEY=replace-with-your-minimax-api-key
MINIMAX_GROUP_ID=optional-minimax-group-id

# Apify API Token (Optional - for fallback scraping)
APIFY_API_TOKEN=your_apify_token_here

# Puppeteer Configuration
# For Linux (1Panel ARM/Debian): /usr/bin/chromium
# For Windows: C:\Program Files\Google\Chrome\Application\chrome.exe (or leave empty for default)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Social Media Configuration
# Instagram
INSTAGRAM_ACCESS_TOKEN=your-long-lived-page-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# Threads
THREADS_ACCESS_TOKEN=your-threads-access-token
THREADS_USER_ID=your-threads-user-id

# Twitter (X)
TWITTER_ACCESS_TOKEN=your-twitter-oauth2-access-token
# Used only by the guest-token crawler; keep it server-side and never log it.
TWITTER_PUBLIC_BEARER_TOKEN=your-x-public-app-bearer-token
