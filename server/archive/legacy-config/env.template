# Server environment template — copy to server/.env and fill with deployment secrets.
# Never commit actual credentials to this file.

PORT=3501
FRONTEND_URL=http://localhost:3000

# Supabase server configuration (service role must remain server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-your-service-role-key

# Trusted capture caller (for example n8n). This key is accepted only by
# POST /api/process and is mapped to the fixed Supabase user below.
MEDIA_API_KEY=replace-with-a-long-random-secret
MEDIA_API_KEY_USER_ID=replace-with-the-supabase-auth-user-uuid-for-n8n

# MiniMax text analysis / remix
MINIMAX_API_KEY=replace-with-your-minimax-api-key
MINIMAX_GROUP_ID=optional-minimax-group-id

# Optional crawler configuration
APIFY_API_TOKEN=optional-apify-token
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
TWITTER_PUBLIC_BEARER_TOKEN=replace-with-your-x-public-app-bearer-token

# Social publishing credentials (server-side only)
INSTAGRAM_ACCESS_TOKEN=replace-with-instagram-token
INSTAGRAM_ACCOUNT_ID=replace-with-instagram-account-id
THREADS_ACCESS_TOKEN=replace-with-threads-token
THREADS_USER_ID=replace-with-threads-user-id
TWITTER_ACCESS_TOKEN=replace-with-twitter-oauth2-token
